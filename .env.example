# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 环境标识: development / production
DJANGO_ENV=development

# 生产环境必填，开发环境留空即可
SECRET_KEY=your-secret-key-here

# 数据库（生产环境 PostgreSQL）
# 开发环境不需要填，自动使用 SQLite
DB_NAME=oral_screening
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
